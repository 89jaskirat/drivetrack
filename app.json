{
  "expo": {
    "name": "DriveTrack",
    "slug": "drivetrack-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "drivetrack",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121314"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.drivetrack.companion"
    },
    "android": {
      "package": "com.drivetrack.companion",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121314"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "DriveTrack needs access to your photos to attach receipts to expenses.",
          "cameraPermission": "DriveTrack needs camera access to photograph receipts."
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "https://svvbjjzicybdbhprxwfe.supabase.co",
      "supabaseAnonKey": "sb_publishable_hvUd4FJk1YyNixELMN9zUw_HR3vbFy3",
      "googleWebClientId": "168473122241-jghehiblfvn25s8s20o0ibus07fp812a.apps.googleusercontent.com",
      "eas": {
        "projectId": "18afac36-b854-47dc-b51b-05e9235d8977"
      }
    }
  }
}
